{
  "name": "launchstack-cli",
  "version": "0.1.0",
  "description": "A TypeScript CLI for deployment automation, release workflows, changelogs, environments, and project launch operations.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "launchstack": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts src/cli.ts --watch --format cjs,esm --dts",
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "test": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write ."
  },
  "keywords": [
    "launchstack",
    "cli",
    "deployment",
    "release-management",
    "automation",
    "devops",
    "typescript",
    "changelog",
    "environments",
    "workflows"
  ],
  "author": "Williams",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "ora": "^9.4.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "eslint": "latest",
    "prettier": "latest",
    "tsup": "^8.5.1",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}