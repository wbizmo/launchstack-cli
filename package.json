{
  "name": "launchstack-cli",
  "version": "2.0.0",
  "description": "A TypeScript CLI for production-ready backend API scaffolding, deployment automation, configuration management, and developer workflows.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "launchstack": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts src/cli.ts --watch --format cjs,esm --dts",
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts && npm run copy:templates",
    "test": "vitest --config vitest.config.ts",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "test:run": "vitest run --config vitest.config.ts",
    "check": "npm run test:run && npm run build && npm pack --dry-run",
    "copy:templates": "node scripts/copy-templates.cjs",
    "release:check": "npm run test:run && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "launchstack",
    "cli",
    "deployment",
    "release-management",
    "automation",
    "devops",
    "typescript",
    "changelog",
    "environments",
    "workflows",
    "api-scaffolding",
    "fastify",
    "backend-generator",
    "developer-tools",
    "api-generator",
    "project-scaffolding",
    "backend-starter",
    "create-api",
    "fastify-cli",
    "prisma-generator",
    "postgresql-starter",
    "jwt-authentication",
    "openapi-generator",
    "zod-validation",
    "backend-scaffolding",
    "api-starter"
  ],
  "author": "Williams",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "ora": "^9.4.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "eslint": "latest",
    "prettier": "latest",
    "tsup": "^8.5.1",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
