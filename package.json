{
  "name": "launchstack-sdk",
  "version": "0.1.0",
  "description": "A TypeScript SDK for managing product launches, release workflows, changelogs, and deployment metadata.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsup src/index.ts --watch --format cjs,esm --dts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write ."
  },
  "keywords": [
    "sdk",
    "typescript",
    "launch",
    "deployment",
    "release-management",
    "changelog",
    "api-client"
  ],
  "author": "Williams",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "zod": "latest"
  }
}