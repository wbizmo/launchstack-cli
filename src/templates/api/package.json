{
  "name": "{{PROJECT_NAME}}",
  "version": "2.0.2",
  "private": true,
  "description": "{{PROJECT_DISPLAY_NAME}} backend API generated with LaunchStack CLI.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test && npm run build",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "openapi:check": "npm run typecheck && npm test && npm run build",
    "validation:check": "npm run typecheck && npm test && npm run build",
    "docker:build": "docker build -t {{PROJECT_NAME}} .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.production.yml up -d --build",
    "db:wait": "node scripts/wait-for-database.cjs",
    "deploy:prepare": "npm run prisma:deploy && npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.0",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify-type-provider-zod": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "prisma": "6.19.3",
    "tsx": "^4.20.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
